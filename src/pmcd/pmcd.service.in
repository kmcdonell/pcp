[Unit]
Description=Performance Metrics Collector Daemon
Documentation=man:pmcd(1)
After=network-online.target
Before=zabbix-agent.service
 
[Service]
Type=notify
NotifyAccess=all
Restart=always
ExecStart=@PCP_RC_DIR@/pmcd start-systemd
ExecStop=@PCP_RC_DIR@/pmcd stop-systemd
PIDFile=@PCP_RUN_DIR@/pmcd.pid
## Capabilities
## we don't know what capabilities the PMDAs need, but it is hard to imagine
## needing anything beyond this set
#CapabilityBoundingSet=CAP_BPF CAP_CHOWN CAP_DAC_OVERRIDE CAP_IPC_LOCK CAP_PERFMON CAP_SYS_NICE CAP_SETGID CAP_SETUID CAP_SYS_ADMIN CAP_SYS_PACCT CAP_SYS_PTRACE CAP_NET_BIND_SERVICE
#AmbientCapabilities=
## Security
#NoNewPrivileges=true
## Process properties
#UMask=077
## Sandboxing ...
#ProtectSystem=full
#ProtectHome=true
#PrivateTmp=true
#ProtectHostname=true
#ProtectClock=true
#ProtectKernelTunables=true
#ProtectKernelModules=true
#ProtectKernelLogs=true
## ProtectControlGroups blocks cgroup.* metrics
#ProtectControlGroups=false
#RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
#RestrictNamespaces=true
#LockPersonality=true
#MemoryDenyWriteExecute=true
#RestrictRealtime=true
#RestrictSUIDSGID=true
#RemoveIPC=true
## System call filtering
## we don't know which system calls the PMDAs need, but excluding these
## ones seems a safe and sane thing to do
## Notes: @debug needed for kvm.* metrics
#SystemCallFilter=~@clock @cpu-emulation @module @mount @reboot @resources @swap @obsolete @raw-io
#SystemCallArchitectures=native
 
[Install]
WantedBy=multi-user.target
